<!DOCTYPE html>
<html>
<head>
<title>Flappy Bird</title>

<style>
body{
margin:0;
overflow:hidden;
font-family:Arial;
background:linear-gradient(#4ec0ff,#87ceeb);
}

canvas{
display:block;
margin:auto;
}

/* Menu Screens */
.menuScreen{
position:absolute;
top:0;
left:0;
width:100%;
height:100%;
display:flex;
justify-content:center;
align-items:center;
background:rgba(0,0,0,0.7);
color:white;
text-align:center;
}

.menuBox{
background:rgba(0,0,0,0.4);
padding:40px;
border-radius:25px;
box-shadow:0 0 25px rgba(0,0,0,0.5);
}

.menuTitle{
font-size:60px;
margin-bottom:10px;
}

.menuSubtitle{
font-size:18px;
opacity:0.8;
margin-bottom:25px;
}

.menuBird{
width:70px;
height:70px;
border-radius:50%;
background:radial-gradient(#fff799,#ffcc00);
margin:auto;
margin-bottom:25px;
}

.versionText{
margin-top:30px;
font-size:14px;
opacity:0.6;
}

button{
padding:15px 35px;
font-size:22px;
border:none;
border-radius:12px;
cursor:pointer;
background:#ffcc00;
margin:8px;
}

#backMenuBtn{
position:absolute;
top:15px;
right:15px;
padding:10px 18px;
font-size:16px;
border:none;
border-radius:8px;
background:#ffcc00;
cursor:pointer;
display:none;
z-index:1000;
}
</style>
</head>

<body>

<div id="menu" class="menuScreen">
<div class="menuBox">

<div class="menuBird"></div>

<div class="menuTitle">Flappy Bird</div>

<div class="menuSubtitle">
Tap or press any key to fly and avoid the pipes
</div>

<button id="startBtn">Start Game</button>
<button id="controlsBtn">Controls</button>

<div class="versionText">Version 1.0</div>

</div>
</div>

<div id="controlsScreen" class="menuScreen" style="display:none">
<div class="menuBox">

<h2>Controls</h2>

<p>Click or Press Any Key → Flap / Jump</p>
<p>Game Over → Click or Press Key to Restart</p>

<button id="backBtn">Back</button>

</div>
</div>

<button id="backMenuBtn">Back to Menu</button>

<canvas id="game" width="400" height="600"></canvas>

<script>

const canvas=document.getElementById("game");
const ctx=canvas.getContext("2d");

const menu=document.getElementById("menu");
const controlsScreen=document.getElementById("controlsScreen");

const startBtn=document.getElementById("startBtn");
const controlsBtn=document.getElementById("controlsBtn");
const backBtn=document.getElementById("backBtn");
const backMenuBtn=document.getElementById("backMenuBtn");

let gameStarted=false;
let gameOver=false;

/* Bird */
let bird={
x:100,
y:250,
radius:18,
gravity:0.6,
lift:-10,
velocity:0
};

/* Wing Animation */
let wingAngle=0;
let wingSpeed=0.25;

/* Pipes */
let pipes=[];
let score=0;
let highScore=localStorage.getItem("flappyHigh")||0;
let frame=0;

/* Clouds */
let clouds=[];

startBtn.onclick=()=>{
menu.style.display="none";
backMenuBtn.style.display="block";
gameStarted=true;
resetGame();
};

controlsBtn.onclick=()=>{
controlsScreen.style.display="flex";
};

backBtn.onclick=()=>{
controlsScreen.style.display="none";
};

backMenuBtn.onclick=()=>{
gameStarted=false;
gameOver=false;

menu.style.display="flex";
backMenuBtn.style.display="none";

bird.y=250;
bird.velocity=0;
pipes=[];
clouds=[];
score=0;
frame=0;
};

document.addEventListener("keydown",flap);
document.addEventListener("click",flap);

function flap(){
if(!gameStarted) return;

if(!gameOver){
bird.velocity=bird.lift;
}else{
resetGame();
}
}

function resetGame(){

if(score>highScore){
highScore=score;
localStorage.setItem("flappyHigh",highScore);
}

bird.y=250;
bird.velocity=0;
pipes=[];
clouds=[];
score=0;
frame=0;
gameOver=false;
}

function createPipe(){
let gap=160;
let topHeight=Math.random()*250+60;

pipes.push({
x:400,
top:topHeight,
bottom:topHeight+gap,
width:55,
passed:false
});
}

function createCloud(){
clouds.push({
x:400,
y:Math.random()*200,
speed:0.5+Math.random()*0.5,
size:40+Math.random()*40
});
}

function drawClouds(){

ctx.fillStyle="rgba(255,255,255,0.8)";

clouds.forEach(cloud=>{
ctx.beginPath();
ctx.arc(cloud.x,cloud.y,cloud.size,0,Math.PI*2);
ctx.arc(cloud.x+cloud.size*0.6,cloud.y-10,cloud.size*0.7,0,Math.PI*2);
ctx.arc(cloud.x+cloud.size*1.2,cloud.y,cloud.size*0.8,0,Math.PI*2);
ctx.fill();

cloud.x-=cloud.speed;
});

clouds=clouds.filter(c=>c.x+c.size*2>0);
}

function drawBird(){

let grad=ctx.createRadialGradient(
bird.x-6,bird.y-6,5,
bird.x,bird.y,bird.radius
);

grad.addColorStop(0,"#fff799");
grad.addColorStop(1,"#ffcc00");

ctx.beginPath();
ctx.arc(bird.x,bird.y,bird.radius,0,Math.PI*2);
ctx.fillStyle=grad;
ctx.fill();

ctx.lineWidth=2;
ctx.strokeStyle="#d4a600";
ctx.stroke();

/* Animated Wing */

let wingY=bird.y+Math.sin(wingAngle)*6;

ctx.beginPath();
ctx.ellipse(
bird.x-2,
wingY,
12,
8,
Math.sin(wingAngle)*0.5,
0,
Math.PI*2
);

ctx.fillStyle="#f4b400";
ctx.fill();

/* Eye */
ctx.beginPath();
ctx.arc(bird.x+7,bird.y-6,5,0,Math.PI*2);
ctx.fillStyle="white";
ctx.fill();

ctx.beginPath();
ctx.arc(bird.x+8,bird.y-6,2.5,0,Math.PI*2);
ctx.fillStyle="black";
ctx.fill();

/* Beak */
ctx.beginPath();
ctx.moveTo(bird.x+bird.radius,bird.y);
ctx.lineTo(bird.x+bird.radius+12,bird.y-4);
ctx.lineTo(bird.x+bird.radius+12,bird.y+4);
ctx.closePath();
ctx.fillStyle="orange";
ctx.fill();
}

function drawPipes(){

pipes.forEach(pipe=>{

ctx.fillStyle="#2ecc71";

ctx.fillRect(pipe.x,0,pipe.width,pipe.top);
ctx.fillRect(pipe.x,pipe.bottom,pipe.width,600-pipe.bottom);

ctx.fillStyle="#27ae60";
ctx.fillRect(pipe.x-6,pipe.top-18,pipe.width+12,18);
ctx.fillRect(pipe.x-6,pipe.bottom,pipe.width+12,18);

ctx.fillStyle="rgba(255,255,255,0.2)";
ctx.fillRect(pipe.x+4,0,3,pipe.top);
ctx.fillRect(pipe.x+4,pipe.bottom,3,600-pipe.bottom);
});
}

function updatePipes(){

pipes.forEach(pipe=>{

pipe.x-=2.5;

if(
bird.x+bird.radius>pipe.x &&
bird.x-bird.radius<pipe.x+pipe.width &&
(bird.y-bird.radius<pipe.top ||
bird.y+bird.radius>pipe.bottom)
){
gameOver=true;
}

if(!pipe.passed && pipe.x+pipe.width<bird.x){
score++;
pipe.passed=true;
}
});

pipes=pipes.filter(p=>p.x+p.width>0);
}

function drawGround(){
ctx.fillStyle="#d4ac0d";
ctx.fillRect(0,580,400,20);
}

function drawScore(){

ctx.fillStyle="white";
ctx.font="22px Arial";

ctx.fillText("Score: "+score,10,30);
ctx.fillText("High: "+highScore,10,60);
}

function update(){

requestAnimationFrame(update);

ctx.clearRect(0,0,400,600);

if(!gameStarted) return;

if(!gameOver){

wingAngle+=wingSpeed;

bird.velocity+=bird.gravity;
bird.y+=bird.velocity;

if(bird.y+bird.radius>580){
gameOver=true;
}

if(frame%90===0){
createPipe();
}

if(frame%300===0){
createCloud();
}

updatePipes();
frame++;
}

drawClouds();
drawPipes();
drawBird();
drawGround();
drawScore();

if(gameOver){

ctx.fillStyle="red";
ctx.font="40px Arial";
ctx.fillText("GAME OVER",80,300);
}
}

update();

</script>

</body>
</html>
